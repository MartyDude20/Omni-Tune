{
  "name": "omnitune",
  "version": "1.0.2",
  "description": "Virtuix Omni One game profile tuner",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/run.js dev",
    "build": "node scripts/run.js build && electron-builder",
    "pack": "node scripts/run.js build && electron-builder --dir",
    "preview": "node scripts/run.js preview"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/jszip": "^3.4.1",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "33.2.1",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.virtuix.omnitune",
    "productName": "OmniTune",
    "icon": "resources/icon.png",
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "MartyDude20",
      "repo": "Omni-Tune"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OmniTune"
    },
    "extraResources": [
      {
        "from": "resources/vr-helper.exe",
        "to": "vr-helper.exe"
      },
      {
        "from": "resources/openvr_api.dll",
        "to": "openvr_api.dll"
      },
      {
        "from": "resources/Logo16.png",
        "to": "Logo16.png"
      },
      {
        "from": "resources/Logo64.png",
        "to": "Logo64.png"
      },
      {
        "from": "resources/Logo256.png",
        "to": "Logo256.png"
      }
    ]
  }
}
